{
  "name": "@nordnet/ui",
  "version": "0.0.0",
  "author": "Nordnet <frontend@nordnet.se> (https://nordnet.se)",
  "repository": "https://github.com/nordnet/ui",
  "bugs": "https://github.com/nordnet/ui/issues",
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "dist/types",
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "node": "18.x || 20.x",
    "npm": "9 || 10"
  },
  "scripts": {
    "test": "TZ=UTC jest",
    "tdd": "npm run test -- --watch",
    "test-ci": "TZ=UTC jest --coverage --ci && codecov",
    "dev:start": "storybook dev -p 6006",
    "dev": "NODE_OPTIONS=--openssl-legacy-provider sh scripts/start-storybook.sh",
    "lint:js": "eslint --ext=.tsx --ext=.ts src",
    "lint:css": "stylelint './src/**/*.{ts,tsx}'",
    "lint:ts": "tsc",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:ts",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:css": "stylelint --fix './src/**/*.{ts,tsx}'",
    "babel:esm": "NODE_ENV=production BABEL_ENV=esm babel -d dist/esm src/ --extensions=.ts,.tsx --copy-files",
    "babel:cjs": "NODE_ENV=production babel -d dist/cjs src/ --extensions=.ts,.tsx --copy-files",
    "build": "rimraf dist && npm run babel:esm && npm run babel:cjs && tsc && rimraf dist/**/*.types.js dist/**/*.d.js dist/**/*.stories.js",
    "build-storybook": "storybook build",
    "now-build": "NODE_OPTIONS=--openssl-legacy-provider storybook build",
    "commit": "git-cz",
    "semantic-release": "semantic-release",
    "prepublishOnly": "npm run build"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@mui/base": "5.0.0-beta.2",
    "@nordnet/design-tokens": "2.0.1",
    "@popperjs/core": "^2.11.6",
    "@xstate/react": "^3.2.2",
    "color": "^4.0.1",
    "date-fns": "^2.23.0",
    "framer-motion": "^10.0.0",
    "ramda": "^0.29.0",
    "react-focus-lock": "^2.9.2",
    "react-intl": "^6.2.1",
    "react-popper": "^2.3.0",
    "react-remove-scroll": "^2.5.7",
    "react-uid": "^2.3.3",
    "scroll-into-view-if-needed": "^2.2.28",
    "styled-components": "6.0.8",
    "stylis": "4.3.0",
    "use-ssr": "^1.0.24",
    "xstate": "^4.23.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@babel/cli": "7.23.4",
    "@babel/core": "7.23.3",
    "@babel/preset-env": "7.23.3",
    "@babel/preset-react": "7.23.3",
    "@babel/preset-typescript": "7.23.3",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@storybook/addon-a11y": "7.5.3",
    "@storybook/addon-essentials": "^7.5.3",
    "@storybook/addon-storyshots": "^7.5.3",
    "@storybook/addon-storysource": "7.5.3",
    "@storybook/addons": "^7.5.3",
    "@storybook/react": "^7.5.3",
    "@storybook/react-webpack5": "7.5.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "14.5.1",
    "@types/color": "3.0.6",
    "@types/jest": "29.5.9",
    "@types/lodash": "^4.14.172",
    "@types/node": "^16.7.1",
    "@types/ramda": "0.29.7",
    "@types/react": "18.2.38",
    "@types/react-dom": "18.2.16",
    "@types/react-router-dom": "5.3.3",
    "@types/styled-components": "5.1.31",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "6.12.0",
    "babel-plugin-ramda": "2.1.1",
    "babel-plugin-react-remove-properties": "^0.3.0",
    "babel-plugin-styled-components": "2.1.4",
    "babel-plugin-transform-remove-imports": "1.7.1",
    "babel-preset-react-app": "^10.0.0",
    "codecov": "3.8.3",
    "copy-to-clipboard": "^3.3.3",
    "csstype": "^3.0.8",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "7.32.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "4.3.0",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-jest": "24.7.0",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.24.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-storybook": "^0.6.15",
    "git-cz": "4.9.0",
    "jest": "29.7.0",
    "jest-date-mock": "^1.0.8",
    "jest-environment-jsdom": "^29.7.0",
    "jest-styled-components": "^7.0.5",
    "lodash": "^4.17.21",
    "postcss-styled-syntax": "^0.5.0",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "9.0.1",
    "react-router": "^6.4.3",
    "react-router-dom": "^6.4.3",
    "rimraf": "5.0.5",
    "semantic-release": "^22.0.6",
    "storybook": "7.5.3",
    "storybook-addon-intl": "3.2.0",
    "storybook-dark-mode": "^3.0.1",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "typescript": "^5.2.2"
  }
}
