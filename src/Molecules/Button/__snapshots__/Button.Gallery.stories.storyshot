  display: inline-flex;
  padding: 4px 12px;
  min-height: 32px;
  background-color: transparent;
  color: #336BFF;
  border: none;
  border-radius: 0;
  cursor: pointer;
}

.c28::before {
  content: '';
  display: block;
  position: absolute;
  border: 2px solid #336BFF;
  top: 0;
  left: 0;
  width: calc(100% - 4px);
  height: calc(100% - 4px);
}

.c28:hover {
  color: #2650BF;
}

.c28:hover::before {
  border-color: #2650BF;
}

.c28:active {
  color: #1F4099;
}

.c28:active::before {
  border-color: #1F4099;
}

