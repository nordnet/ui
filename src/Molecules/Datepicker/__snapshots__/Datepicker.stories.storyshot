  -webkit-justify-content: center;
  -ms-flex-pack: center;
  justify-content: center;
  -webkit-align-items: center;
  -webkit-box-align: center;
  -ms-flex-align: center;
  align-items: center;
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  color: gray;
  margin-bottom: 2px;
}

.c40.today {
  border: 1px solid #F5F5F5;
}

.c40:hover {
  border: 1px solid #0046FF;
}

.c40.selected {
  background: #0046FF;
}

.c40.selected span {
  color: white;
}

.c40.disabled {
