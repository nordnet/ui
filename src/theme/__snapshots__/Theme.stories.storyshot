exports[`Storyshots Others / Theme Light Colors 1`] = `
Array [
  .c0 {
  padding-top: 16px;
  padding-bottom: 16px;
  background-color: transparent;
}

.c1 {
  font-family: 'Nordnet Sans Mono',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  color: #282823;
  margin: 0;
  font-weight: 800;
  font-size: 24px;
  line-height: 1.1666666666666667;
}

.c2 {
  font-family: 'Nordnet Sans Mono',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  color: #282823;
  margin: 0;
  font-weight: 400;
  font-size: 16px;
  line-height: 1.5;
}

@supports (-webkit-overflow-scrolling:touch): {

}

@media (min-width:760px) {
  .c1 {
    font-size: 28px;
    line-height: 1.1428571428571428;
  }
}

<div
    className="c0"
  >
    <h1
      className="Typography__Span-sc-10mju41-0 c1"
    >
      Light Colors
    </h1>
    <span
      className="Typography__Span-sc-10mju41-0 c2"
    >
      Do not use this unless you have very specific needs for this. For example when you do not want the color to change on dark mode. For instance text on background image. 
      <br />
      Use like 
      <pre>
        theme.lightColor.text
      </pre>
    </span>
  </div>,
  .c0 {
  width: 100%;
  table-layout: fixed;
  border-collapse: collapse;
  color: #282823;
}

.c1 {
  width: 100%;
  border-bottom: 1px solid #EBEBE8;
}

.c4 {
  width: 100%;
  overflow: auto;
}

.c2 {
  height: 100%;
  padding: 8px 0;
  overflow: hidden;
}

.c2:not(:first-child) {
  border-top: 1px solid #EBEBE8;
}

.c5 {
  height: 100%;
  padding: 8px 4px;
  text-align: left;
}

.c5:first-child {
  padding-left: 0;
}

.c5:last-child {
  padding-right: 0;
}

.c3 {
  color: #6E6E6E;
  font-weight: normal;
  height: 100%;
  padding: 8px 4px;
  text-align: left;
  width: auto;
}

.c3:first-child {
  padding-left: 0;
}

.c3:last-child {
  padding-right: 0;
}

.c43 {
  box-sizing: border-box;
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  margin-left: -2px;
  margin-right: -2px;
}

.c43 > * {
  padding-left: 2px;
  padding-right: 2px;
}

.c43 > *:not(:first-child) {
  padding-top: 0;
}

.c6 {
